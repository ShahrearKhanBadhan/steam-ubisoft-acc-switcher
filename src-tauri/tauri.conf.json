{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam & Ubisoft Acc Switcher",
  "version": "1.0.0",
  "identifier": "com.shahr.steam-acc-switcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Steam & Ubisoft Acc Switcher",
        "width": 400,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "theme": "Dark",
        "center": true,
        "alwaysOnTop": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
